# /srv/kawa/env/kawa.env — 全站唯一 env 檔，backend / frontend / database 三個容器共用
# 每個值只在這裡出現一次；改完 `docker compose up -d` 重建生效

# ── 前後端共用 ──
JWT_SECRET=change-me

# ── database（postgres 初始化用；既有 dbdata 不吃新值，換密碼要另外 ALTER USER）──
POSTGRES_PASSWORD=change-me

# ── backend ──
APP_PORT=3000
# 密碼同 POSTGRES_PASSWORD，改的話兩處一起改
DATABASE_URL=postgres://kawa:change-me@database:5432
REDIS_HOST=valkey
UPLOAD_PATH=/app/uploads
TORRENT_PATH=/app/torrents
TRUST_CF_HEADER=true
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_SECRET=
LINE_CLIENT_SECRET=

# ── frontend ──
# 內網 hostname 是 compose service 名稱（backend），不再是舊的 api-server-axum
API_URL=http://backend:3000
API_PUBLIC_URL=https://axum.kawa.homes
WS_URL=wss://axum.kawa.homes
